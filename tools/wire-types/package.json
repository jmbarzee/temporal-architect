{
  "name": "@temporal-architect/wire-types",
  "version": "0.9.2",
  "description": "TypeScript projection of twf's JSON wire contract, generated from the Go DTO layer. Consumed type-only by the visualizer and the VS Code extension.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/jmbarzee/temporal-architect",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmbarzee/temporal-architect.git",
    "directory": "tools/wire-types"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "prepack": "cp ../../LICENSE LICENSE",
    "postpack": "rm -f LICENSE"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
