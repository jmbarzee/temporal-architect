{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jmbarzee/temporal-architect/tools/lsp/cmd/twf/twf.schema.json",
  "$schemaVersion": "1.2.0",
  "title": "twf JSON envelope",
  "description": "Stable wire contract emitted by `twf parse`, `twf symbols --json`, `twf graph --json`, and `twf graph chunks --json`. Adding optional fields or new diagnostic codes is non-breaking; renaming or removing them is breaking and requires coordinated bumps across downstream consumers. `$schemaVersion` follows semver — minor bumps are additive, major bumps signal a breaking change to the wire shape.",
  "type": "object",
  "required": [
    "summary",
    "diagnostics"
  ],
  "additionalProperties": true,
  "properties": {
    "summary": {
      "$ref": "#/$defs/Summary"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Diagnostic"
      }
    },
    "definitions": {
      "description": "Present on `twf parse`. The AST definitions array. Item shape is intentionally permissive in this schema — see tools/visualizer/src/types/ast.ts for the discriminated union.",
      "type": "array"
    },
    "symbols": {
      "description": "Present on `twf symbols --json`. The symbol list (workflows, activities, workers, namespaces, nexus services).",
      "type": "array"
    },
    "graph": {
      "description": "Present on `twf graph --json`. The resolved deployment graph: nodes are runtime deployments (definition × instantiation), edges are confirmed dispatches.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/Graph"
        }
      ]
    },
    "chunks": {
      "description": "Present on `twf graph chunks --json`. The topology-based decomposition: the #1 hard partition of authorable definitions into chunks, the inter-chunk contract dependency DAG, and (when a ceiling is set) #2 ranked soft divisions.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/Decomposition"
        }
      ]
    }
  },
  "$defs": {
    "Position": {
      "type": "object",
      "required": [
        "line",
        "column"
      ],
      "additionalProperties": false,
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0
        },
        "column": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Summary": {
      "type": "object",
      "required": [
        "namespaces",
        "workers",
        "workflows",
        "activities",
        "nexusServices"
      ],
      "additionalProperties": true,
      "properties": {
        "namespaces": {
          "type": "integer",
          "minimum": 0
        },
        "workers": {
          "type": "integer",
          "minimum": 0
        },
        "workflows": {
          "type": "integer",
          "minimum": 0
        },
        "activities": {
          "type": "integer",
          "minimum": 0
        },
        "nexusServices": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Diagnostic": {
      "type": "object",
      "required": [
        "severity",
        "kind",
        "code",
        "start",
        "end",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "parse",
            "resolve",
            "validate",
            "graph"
          ]
        },
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "file": {
          "type": "string"
        },
        "start": {
          "$ref": "#/$defs/Position"
        },
        "end": {
          "$ref": "#/$defs/Position"
        },
        "message": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "parse"
              }
            }
          },
          "then": {
            "properties": {
              "code": {
                "enum": [
                  "SYNTAX"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "resolve"
              }
            }
          },
          "then": {
            "properties": {
              "code": {
                "enum": [
                  "DUPLICATE_WORKFLOW",
                  "DUPLICATE_ACTIVITY",
                  "DUPLICATE_WORKER",
                  "DUPLICATE_NAMESPACE",
                  "DUPLICATE_NEXUS_SERVICE",
                  "DUPLICATE_ENDPOINT",
                  "UNDEFINED_ACTIVITY",
                  "UNDEFINED_WORKFLOW",
                  "UNDEFINED_SIGNAL",
                  "UNDEFINED_UPDATE",
                  "UNDEFINED_CONDITION",
                  "UNDEFINED_PROMISE_OR_CONDITION",
                  "CONDITION_RESULT_BINDING",
                  "NEXUS_ASYNC_UNDEFINED_WORKFLOW",
                  "NEXUS_UNDEFINED_ENDPOINT",
                  "NEXUS_UNRESOLVED_ENDPOINT",
                  "NEXUS_UNDEFINED_SERVICE",
                  "NEXUS_UNRESOLVED_SERVICE",
                  "NEXUS_NO_OPERATION",
                  "WORKER_UNDEFINED_WORKFLOW",
                  "WORKER_UNDEFINED_ACTIVITY",
                  "WORKER_UNDEFINED_NEXUS_SERVICE",
                  "NAMESPACE_UNDEFINED_WORKER"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "validate"
              }
            }
          },
          "then": {
            "properties": {
              "code": {
                "enum": [
                  "EMPTY_WORKFLOW",
                  "EMPTY_ACTIVITY",
                  "EMPTY_WORKER",
                  "EMPTY_NAMESPACE",
                  "MISSING_TASK_QUEUE",
                  "MISSING_ENDPOINT_TASK_QUEUE",
                  "UNCOVERED_WORKFLOW",
                  "UNCOVERED_ACTIVITY",
                  "UNCOVERED_SERVICE",
                  "UNINSTANTIATED_WORKER",
                  "TASK_QUEUE_IDENTICAL",
                  "TASK_QUEUE_MISMATCH",
                  "EXPLICIT_ROUTING_MISMATCH",
                  "IMPLICIT_ROUTING_MISMATCH",
                  "ENDPOINT_SERVICE_LINKAGE"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "graph"
              }
            }
          },
          "then": {
            "properties": {
              "code": {
                "enum": [
                  "DISPATCH_NO_REACHABLE_DEPLOYMENT",
                  "SIGNAL_TARGET_NOT_SAMPLED"
                ]
              }
            }
          }
        }
      ]
    },
    "Graph": {
      "type": "object",
      "required": [
        "summary",
        "nodes",
        "edges",
        "coarsenedEdges",
        "unresolved",
        "diagnostics"
      ],
      "additionalProperties": false,
      "properties": {
        "summary": {
          "$ref": "#/$defs/GraphSummary"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GraphNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GraphEdge"
          }
        },
        "coarsenedEdges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CoarsenedEdge"
          }
        },
        "unresolved": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Unresolved"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GraphDiagnostic"
          }
        }
      }
    },
    "GraphSummary": {
      "type": "object",
      "required": [
        "nodes",
        "edges",
        "coarsenedEdges",
        "unresolved",
        "diagnostics"
      ],
      "additionalProperties": false,
      "properties": {
        "nodes": {
          "type": "integer",
          "minimum": 0
        },
        "edges": {
          "type": "integer",
          "minimum": 0
        },
        "coarsenedEdges": {
          "type": "integer",
          "minimum": 0
        },
        "unresolved": {
          "type": "integer",
          "minimum": 0
        },
        "diagnostics": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "GraphNode": {
      "type": "object",
      "required": [
        "id",
        "definition"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "worker": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "queue": {
          "type": "string"
        },
        "orphan": {
          "type": "boolean"
        }
      }
    },
    "GraphEdge": {
      "type": "object",
      "required": [
        "from",
        "to",
        "kind",
        "line"
      ],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "containment",
            "activityCall",
            "workflowCall",
            "nexusCall",
            "asyncBacking",
            "signalSend",
            "nexusRoute"
          ]
        },
        "line": {
          "type": "integer",
          "minimum": 0
        },
        "routing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "explicit": {
              "type": "string"
            },
            "nexusEndpoint": {
              "type": "string"
            }
          }
        }
      }
    },
    "CoarsenedEdge": {
      "type": "object",
      "required": [
        "from",
        "to",
        "tier",
        "weight"
      ],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "tier": {
          "type": "string",
          "enum": [
            "worker",
            "namespace"
          ]
        },
        "weight": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "Unresolved": {
      "type": "object",
      "required": [
        "from",
        "name",
        "kind",
        "line"
      ],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "activityCall",
            "workflowCall",
            "nexusCall",
            "asyncBacking",
            "signalSend"
          ]
        },
        "line": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "GraphDiagnostic": {
      "type": "object",
      "required": [
        "severity",
        "code",
        "message",
        "line"
      ],
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning"
          ]
        },
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "message": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Decomposition": {
      "type": "object",
      "required": [
        "nodes",
        "roots",
        "chunks",
        "chunkEdges",
        "floor",
        "ceiling"
      ],
      "additionalProperties": false,
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ChunkNode"
          }
        },
        "roots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ChunkRootDecl"
          }
        },
        "chunks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Chunk"
          }
        },
        "chunkEdges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ChunkEdge"
          }
        },
        "floor": {
          "type": "integer"
        },
        "ceiling": {
          "type": "integer"
        }
      }
    },
    "ChunkNode": {
      "description": "One authorable definition (deployment-duplicates collapsed). Kind is workflow / activity / nexusOperation.",
      "type": "object",
      "required": [
        "key",
        "kind",
        "name",
        "complexity"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "workflow",
            "activity",
            "nexusOperation"
          ]
        },
        "name": {
          "type": "string"
        },
        "workers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "namespaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "langs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "complexity": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "ChunkRootDecl": {
      "description": "A heuristic entry point. source is heuristic this pass; declared is reserved for #7.",
      "type": "object",
      "required": [
        "key",
        "source",
        "reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "heuristic",
            "declared"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Chunk": {
      "description": "One element of the #1 hard partition (a weakly-connected component of the binding+soft subgraph). Every definition lands in exactly one chunk.",
      "type": "object",
      "required": [
        "id",
        "roots",
        "members",
        "complexity"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "roots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ChunkRootReach"
          }
        },
        "members": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "overlap": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "complexity": {
          "type": "integer",
          "minimum": 0
        },
        "cyclic": {
          "type": "boolean"
        },
        "belowFloor": {
          "type": "boolean"
        },
        "mergeInto": {
          "type": "string"
        },
        "divisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Division"
          }
        }
      }
    },
    "ChunkRootReach": {
      "type": "object",
      "required": [
        "key",
        "reaches"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "reaches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ChunkEdge": {
      "description": "A contract-cut dependency between two hard chunks (via == nexusCall).",
      "type": "object",
      "required": [
        "from",
        "to",
        "via"
      ],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "via": {
          "type": "string",
          "enum": [
            "nexusCall"
          ]
        }
      }
    },
    "Division": {
      "description": "One candidate way to cut an over-ceiling chunk into sections, with a dependency DAG among them. Rank 1 is the most balanced.",
      "type": "object",
      "required": [
        "strategy",
        "rank",
        "sections",
        "dag",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "tree",
            "nexus",
            "worker",
            "namespace",
            "hub"
          ]
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Section"
          }
        },
        "dag": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SectionEdge"
          }
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "Section": {
      "description": "One proposed sub-unit of a divided chunk. id/members/complexity are authoritative; divisions, when present, is the recursive refinement of a section still over the ceiling (a single locally-best sub-division).",
      "type": "object",
      "required": [
        "id",
        "members",
        "complexity"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "members": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "complexity": {
          "type": "integer",
          "minimum": 0
        },
        "divisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Division"
          }
        }
      }
    },
    "SectionEdge": {
      "description": "Orders two sections in a division: From depends on (calls into) To.",
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      }
    }
  }
}